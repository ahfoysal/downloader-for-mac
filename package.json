{
  "name": "youtube-music-downloader",
  "version": "4.0.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ahfoysal/downloader-for-mac.git"
  },
  "private": true,
  "author": {
    "name": "ahfoysal",
    "email": "ahfoysal30@gmail.com",
    "url": "https://github.com/ahfoysal"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/ahfoysal/downloader-for-mac/issues"
  },
  "homepage": "https://github.com/ahfoysal/downloader-for-mac",
  "description": "Native macOS + Windows app for downloading audio & video from YouTube and other sites. yt-dlp + ffmpeg, Spotify-style player with lyrics, library, browser extension, channel subscriptions.",
  "main": "main.js",
  "scripts": {
    "postinstall": "node scripts/fetch-binaries.js",
    "fetch-binaries": "node scripts/fetch-binaries.js",
    "start": "electron .",
    "dist": "cross-env USE_HARD_LINKS=false ELECTRON_BUILDER_DISABLE_MIRROR=true electron-builder --win --x64",
    "dist:mac": "cross-env USE_HARD_LINKS=false ELECTRON_BUILDER_DISABLE_MIRROR=true electron-builder --mac --arm64",
    "dist:mac:universal": "cross-env USE_HARD_LINKS=false ELECTRON_BUILDER_DISABLE_MIRROR=true electron-builder --mac --universal"
  },
  "build": {
    "appId": "com.ahfoysal.downloader-for-mac",
    "productName": "Downloader for Mac",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icon.ico",
      "extraResources": [
        {
          "from": "bin/yt-dlp.exe",
          "to": "yt-dlp.exe"
        },
        {
          "from": "bin/ffmpeg.exe",
          "to": "ffmpeg.exe"
        }
      ]
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.music",
      "identity": null,
      "extraResources": [
        {
          "from": "bin/yt-dlp",
          "to": "yt-dlp"
        },
        {
          "from": "bin/ffmpeg-arm64",
          "to": "ffmpeg-arm64"
        },
        {
          "from": "bin/ffmpeg-x64",
          "to": "ffmpeg-x64"
        },
        {
          "from": "scripts/native-host.js",
          "to": "scripts/native-host.js"
        },
        {
          "from": "browser-extension",
          "to": "browser-extension"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "node-id3": "^0.2.9",
    "yt-dlp-wrap": "^2.3.2"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "electron": "^32.0.0",
    "electron-builder": "^25.0.0"
  }
}
