{
  "name": "youtube-music-downloader",
  "version": "1.0.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Refloow/YouTube-Music-Download.git"
  },
  "private": true,
  "author": {
    "name": "Refloow",
    "email": "legal@refloow.com",
    "url": "https://refloow.com"
  },
  "contributors": [
    {
      "name": "Veljko Vuckovic",
      "url": "https://github.com/Refloow"
    }
  ],
  "funding": {
    "type": "individual",
    "url": "https://refloow.com"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Refloow/YouTube-Music-Download/issues"
  },
  "homepage": "https://github.com/Refloow/YouTube-Music-Download",
  "description": "Simple native macOS app for downloading audio from YouTube.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "cross-env USE_HARD_LINKS=false ELECTRON_BUILDER_DISABLE_MIRROR=true electron-builder --win --x64",
    "dist:mac": "cross-env USE_HARD_LINKS=false ELECTRON_BUILDER_DISABLE_MIRROR=true electron-builder --mac --arm64",
    "dist:mac:universal": "cross-env USE_HARD_LINKS=false ELECTRON_BUILDER_DISABLE_MIRROR=true electron-builder --mac --universal"
  },
  "build": {
    "appId": "com.refloow.ytdownloader",
    "productName": "Downloader for Mac",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icon.ico",
      "extraResources": [
        {
          "from": "bin/yt-dlp.exe",
          "to": "yt-dlp.exe"
        },
        {
          "from": "bin/ffmpeg.exe",
          "to": "ffmpeg.exe"
        }
      ]
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.music",
      "identity": null,
      "extraResources": [
        {
          "from": "bin/yt-dlp",
          "to": "yt-dlp"
        },
        {
          "from": "bin/ffmpeg",
          "to": "ffmpeg"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "ffmpeg-static": "^5.1.0",
    "yt-dlp-wrap": "^2.3.2"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "electron": "^29.0.0",
    "electron-builder": "^23.6.0"
  }
}